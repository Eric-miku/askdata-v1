# LLM configuration (DeepSeek or any OpenAI-compatible API)
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=your-api-key-here
LLM_MODEL_NAME=deepseek-v4-pro
LLM_THINKING_ENABLED=true
LLM_REASONING_EFFORT=high

# BIRD dataset path
BIRD_DATA_DIR=data/bird

# Optional external company database URL. Register managed data sources as env:COMPANY_MYSQL_URL.
# Example format: mysql+pymysql://readonly_user:password@host:13306/database?charset=utf8mb4
COMPANY_MYSQL_URL=

# Optional: when set, knowledge/data-source mutations require X-Admin-Token.
ADMIN_API_TOKEN=
ASKDATA_STATE_DIR=.checkpoints
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Query governance limits.
QUERY_MAX_ROWS=1000
EXPORT_MAX_ROWS=10000
MAX_RESULT_BYTES=10485760
SQL_MAX_JOINS=8
SQL_MAX_SUBQUERY_DEPTH=4
SQL_STATEMENT_TIMEOUT_SECONDS=15
SLOW_QUERY_MS=2000

# Frontend identity forwarded as X-User-ID. Replace with gateway/SSO identity in production.
VITE_USER_ID=local-user
VITE_ADMIN_API_TOKEN=
